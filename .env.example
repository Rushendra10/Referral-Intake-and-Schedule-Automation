# =============================================================================
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit secrets.
# =============================================================================

# TinyFish browser automation API key
# Get yours at: https://agent.tinyfish.ai/api-keys
TINYFISH_API_KEY=sk-tinyfish-YOUR_KEY_HERE

# Public base URL of this app so TinyFish can reach the demo pages.
# Local dev: run `ngrok http 3000` and paste the https URL here.
# Production: your Vercel deployment URL.
# Omit this (or leave blank) to use the built-in simulated fallback.
TINYFISH_TARGET_BASE_URL=https://your-app.vercel.app
